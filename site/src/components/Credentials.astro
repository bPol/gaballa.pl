---
import type { Locale } from '../content/site';
import { content } from '../content/site';

type Props = { locale: Locale };
const { locale } = Astro.props;
const c = content[locale];
---

<section id="credentials" class="section">
  <div class="container">
    <div class="creds__header">
      <span class="eyebrow">{c.credentials.eyebrow}</span>
      <h2>{c.credentials.title}</h2>
    </div>

    <ul class="creds__grid">
      {c.credentials.items.map((item) => (
        <li class="cred">
          <h3>{item.title}</h3>
          <p class="cred__subtitle">{item.subtitle}</p>
          {item.note && <p class="cred__note">{item.note}</p>}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .creds__header {
    margin-bottom: 3rem;
    max-width: var(--text-width);
  }

  .creds__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .cred {
    padding: 1.75rem;
    border-left: 3px solid var(--color-terra);
    background: var(--color-bg-alt);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .cred h3 {
    margin: 0 0 0.25rem;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
  }

  .cred__subtitle {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-sage-deep);
    font-weight: 500;
  }

  .cred__note {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-ink-soft);
  }
</style>
