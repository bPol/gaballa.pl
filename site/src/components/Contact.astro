---
import type { Locale } from '../content/site';
import { content } from '../content/site';

type Props = { locale: Locale };
const { locale } = Astro.props;
const c = content[locale];
---

<section id="contact" class="section">
  <div class="container contact">
    <div class="contact__copy">
      <span class="eyebrow">{c.contact.eyebrow}</span>
      <h2>{c.contact.title}</h2>
      <p class="lede">{c.contact.lede}</p>
    </div>

    <div class="contact__card">
      <dl>
        <div>
          <dt>{c.contact.emailLabel}</dt>
          <dd><a href={`mailto:${c.contact.email}`}>{c.contact.email}</a></dd>
        </div>
        {c.contact.phone && (
          <div>
            <dt>{c.contact.phoneLabel}</dt>
            <dd><a href={`tel:${c.contact.phone.replace(/\s/g, '')}`}>{c.contact.phone}</a></dd>
          </div>
        )}
      </dl>
      <a class="btn btn--primary" href={c.contact.bookUrl}>{c.contact.bookCta}</a>
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: 1fr;
    align-items: center;
  }

  .contact__copy {
    max-width: 32rem;
  }

  .contact__card {
    padding: 2.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact__card dl {
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }

  .contact__card dt {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-sage-deep);
    margin-bottom: 0.25rem;
  }

  .contact__card dd {
    margin: 0;
    font-size: 1.0625rem;
    font-family: var(--font-serif);
  }

  .contact__card dd a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 2px;
  }

  .contact__card dd a:hover {
    color: var(--color-terra-deep);
    border-color: var(--color-terra-deep);
  }

  @media (min-width: 900px) {
    .contact {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
