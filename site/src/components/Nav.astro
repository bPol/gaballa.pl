---
import type { Locale } from '../content/site';
import { content } from '../content/site';

type Props = { locale: Locale };
const { locale } = Astro.props;
const c = content[locale];
const base = locale === 'pl' ? '' : '/en';
const otherBase = locale === 'pl' ? '/en/' : '/';
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href={`${base}/`}>Ewelina Gaballa</a>
    <nav class="nav__links" aria-label="Primary">
      <a href={`${base}/#about`}>{c.nav.about}</a>
      <a href={`${base}/#services`}>{c.nav.services}</a>
      <a href={`${base}/#tools`}>{c.nav.tools}</a>
      <a href={`${base}/#credentials`}>{c.nav.credentials}</a>
      <a href={`${base}/#testimonials`}>{c.nav.testimonials}</a>
      <a href={`${base}/#contact`}>{c.nav.contact}</a>
    </nav>
    <a class="nav__lang" href={otherBase} aria-label={c.nav.langLabel}>
      {c.nav.otherLang}
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: saturate(120%) blur(8px);
    -webkit-backdrop-filter: saturate(120%) blur(8px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-line) 60%, transparent);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
  }

  .nav__brand {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .nav__links {
    display: none;
    gap: 1.5rem;
    font-size: 0.9375rem;
  }

  .nav__links a {
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav__links a:hover {
    color: var(--color-ink);
  }

  .nav__lang {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    border: 1px solid var(--color-line);
    color: var(--color-ink);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  .nav__lang:hover {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
    text-decoration: none;
  }

  @media (min-width: 900px) {
    .nav__links {
      display: flex;
    }
  }
</style>
